# JobBot runtime config (copy to .env and fill values)
# Settings use JOBBOT_ prefix and are loaded from repository-root .env.

# Core runtime
JOBBOT_APP_NAME=jobbot
JOBBOT_DATABASE_URL=
JOBBOT_DATA_DIR=

# Thresholds/budgets (optional overrides)
JOBBOT_AUTO_SUBMIT_THRESHOLD=0.95
JOBBOT_EXTRACTOR_THRESHOLD=0.90
JOBBOT_FIELD_MAPPING_THRESHOLD=0.92
JOBBOT_ANSWER_THRESHOLD=0.88
JOBBOT_MODEL_CALL_DAILY_BUDGET_USD=5.0
JOBBOT_MODEL_CALL_WEEKLY_BUDGET_USD=25.0

# Auto-apply preflight selector-health tuning
JOBBOT_AUTO_APPLY_SELECTOR_PROBE_WINDOW=20
JOBBOT_AUTO_APPLY_SELECTOR_PROBE_MIN_SAMPLE=4
JOBBOT_AUTO_APPLY_SELECTOR_PROBE_FAILURE_RATE_WARNING=0.30
JOBBOT_AUTO_APPLY_SELECTOR_PROBE_FAILURE_RATE_CRITICAL=0.50

# Auto-apply admission policy (enqueue/run guardrails)
JOBBOT_AUTO_APPLY_ADMISSION_SAMPLE_SIZE=5
JOBBOT_AUTO_APPLY_ADMISSION_ENFORCE_ON_ENQUEUE=true
JOBBOT_AUTO_APPLY_MIN_CONFIDENCE_SCORE=0.55
JOBBOT_AUTO_APPLY_REQUIRE_REVIEW_APPROVED=true
JOBBOT_AUTO_APPLY_CANARY_MAX_VERIFIED_PER_HOUR=5
JOBBOT_AUTO_APPLY_CANARY_MAX_VERIFIED_PER_DAY=20
JOBBOT_AUTO_APPLY_CANARY_VENDOR_ALLOWLIST=greenhouse,lever,workday
JOBBOT_AUTO_APPLY_REQUEUE_ACTIONABLE_COOLDOWN_SECONDS=120

# Iterative LLM CV writer (draft -> review -> final)
JOBBOT_LLM_CV_WRITER_ENABLED=true
JOBBOT_LLM_CV_WRITER_TEMPERATURE=0.2
JOBBOT_LLM_CV_WRITER_MAX_TOKENS=1800
JOBBOT_LLM_CV_WRITER_MODEL=gemini-3-flash-preview
JOBBOT_LLM_CV_WRITER_FALLBACK_MODEL=gemini-3.1-flash-lite-preview
JOBBOT_LLM_CV_REVIEWER_MODEL=
JOBBOT_LLM_API_RPM=5

# LLM provider selection
# Supported target values for planned routing: gemini, openai, anthropic
# Start with gemini.
JOBBOT_LLM_PROVIDER=gemini

# Provider keys (set only what you use)
JOBBOT_GEMINI_API_KEY=SET_IN_LOCAL_ENV_ONLY
JOBBOT_OPENAI_API_KEY=
JOBBOT_ANTHROPIC_API_KEY=

